# ── Python runtime ────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/

# ── PyInstaller output ────────────────────────────────────────────────────────
dist/
build/
*.spec

# ── pytest / coverage ─────────────────────────────────────────────────────────
.pytest_cache/
pytest-cache-files-*/
.coverage
htmlcov/

# ── SQLite databases (runtime data) ───────────────────────────────────────────
*.db
*.sqlite
*.sqlite3

# ── OS artefacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/

# ── Claude Code local settings ───────────────────────────────────────────────
.claude/settings.local.json

# ── Misc ──────────────────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
